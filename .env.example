# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais em repositórios.

# URL base do seu Jira Cloud (sem barra no final)
JIRA_BASE_URL=https://suaempresa.atlassian.net

# E-mail da conta de serviço criada para o bot de qualidade
JIRA_EMAIL=bot.qualidade@agricef.com

# API Token gerado em: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=

# IDs do Google Drive (usados pelo patch_config.py)
# Como encontrar: abra o item no Drive/Docs e copie o trecho entre /d/ e /edit na URL
DRIVE_PASTA_ID=
DRIVE_TEMPLATE_ID=
